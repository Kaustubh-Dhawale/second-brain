# Copy this file to ".env" and paste your Firebase web app config values.
# Firebase Console > Project settings > General > Your apps > Web app > SDK setup and configuration.
# All vars MUST start with VITE_ so Vite exposes them to the client bundle.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: turn on Google Calendar two-way sync (free; needs an OAuth Web
# client id from Google Cloud Console). Leave blank to keep the in-app Agenda only.
VITE_GOOGLE_CLIENT_ID=

# Optional: turn on phone push reminders for scheduled tasks. Generate a VAPID
# key pair (npx web-push generate-vapid-keys) and paste the PUBLIC key here.
# Leave blank to keep reminders off. See README.
VITE_VAPID_PUBLIC_KEY=
