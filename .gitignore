# Dependencies & build output (regenerated by `npm install` / `npm run build`)
node_modules
dist
dist-ssr
*.local

# Firebase CLI local state
.firebase
firebase-debug.log

# OS junk
.DS_Store

# NOTE: .env IS committed on purpose. It holds only the Firebase *web* config,
# which is not secret — it already ships inside the public app bundle, and this
# repo is private. Committing it lets GitHub Codespaces and CI build with no
# extra setup. Never put real secrets (service-account keys, tokens) in .env.
